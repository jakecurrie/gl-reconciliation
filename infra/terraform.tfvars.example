prefix      = "glrec"
environment = "dev"

# Azure OpenAI is available in canadaeast — verify at: https://learn.microsoft.com/azure/ai-services/openai/concepts/models
location = "canadaeast"

# PostgreSQL admin username (password is auto-generated and stored in Key Vault)
postgres_admin_login = "pgadmin"

# GPT-4.1-mini model version — check available versions with:
#   az cognitiveservices account deployment list --name <account> --resource-group <rg>
openai_model_version = "2025-04-14"

# ACR SKU: Basic (dev), Standard, or Premium
acr_sku = "Basic"

# ── Azure DevOps ──────────────────────────────────────────────────────────────
# Prerequisite: create the ADO organisation manually at dev.azure.com first

ado_org_url      = "https://dev.azure.com/<your-org>"
ado_project_name = "gl-reconciliation"

# PAT needs: Project (Read & Write), Build (Read & Execute), Service Connections (Read, Query, Manage)
ado_pat = "<ado-personal-access-token>"

github_repo = "jakecurrie/gl-reconciliation"
github_pat  = "<github-personal-access-token>"  # repo scope

sonarcloud_org   = "<sonarcloud-org-key>"
sonarcloud_token = "<sonarcloud-user-token>"

# Service principal for the ADO → Azure service connection
# Create with: az ad sp create-for-rbac --name gl-rec-ado --role Contributor --scopes /subscriptions/<sub-id>
azure_service_principal_id  = "<sp-client-id>"
azure_service_principal_key = "<sp-client-secret>"
